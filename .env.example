# Slack: https://api.slack.com/apps → Your App → OAuth & Permissions / Basic Information
# Socket Mode: enable it, then create an App-Level Token with scope connections:write → SLACK_APP_TOKEN

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Optional: Notion integration token → page previews from notion.so links in threads
# https://www.notion.so/my-integration
NOTION_TOKEN=

# Anthropic — Claude Opus (default model id in code; override with ANTHROPIC_MODEL)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Internal LiteLLM / proxy: send requests here instead of api.anthropic.com (same as LITELLM_BASE_URL)
# Toloka: https://litellm.toloka.network (Cato may be required)
# LITELLM_BASE_URL=https://litellm.toloka.network
# ANTHROPIC_BASE_URL=https://litellm.toloka.network
# Model id must match what your proxy accepts (may differ from public Anthropic ids)
# ANTHROPIC_MODEL=claude-opus-4-6

# Set to 1 to force mock LLM (no Anthropic call) for local testing
# STAFFING_AGENT_MOCK_LLM=0

# Optional: Databricks CLI profile for `python -m staffing_agent --check-dbx` and Node 3 occupation SQL
# (brew install databricks; databricks auth login --profile toloka)
# DATABRICKS_PROFILE=toloka
# Override paths to SQL from Notion Decision Logic (defaults under sql/)
# STAFFING_OCCUPATION_SQL_PATH=
# STAFFING_PTO_SQL_PATH=
# STAFFING_ACTIVE_PROJECTS_SQL_PATH=
# Per-person project rows (join staffing + orders) — shown for recommended people in minimal/compact
# STAFFING_PROJECT_STAFFING_SQL_PATH=
# Run SELECT 1 from Slack replies (adds latency); default off
# STAFFING_AGENT_SLACK_DBX_SMOKE=0

# Reply shape: minimal = краткое саммари + только рекомендация (default); compact = + Node 2 + превью Occupation; full = Phase A + JSON + всё
# STAFFING_AGENT_REPLY_STYLE=minimal

# People & Tags CSV (Notion export) для склейки по email; по умолчанию config/notion_export/staffing_people_tags_all.csv
# STAFFING_PEOPLE_CSV_PATH=

# Projects & Offers Classification CSV — блок «похожие проекты»; по умолчанию config/notion_export/projects_offers_classification_0.csv
# STAFFING_PROJECTS_CLASSIFICATION_CSV_PATH=

# Optional: paste pipeline — post CLI result to a channel (channel ID starts with C)
# python -m staffing_agent --process-paste thread.txt --post-slack-channel C01234567890
