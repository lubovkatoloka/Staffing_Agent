# Slack: https://api.slack.com/apps → Your App → OAuth & Permissions / Basic Information
# Socket Mode: enable it, then create an App-Level Token with scope connections:write → SLACK_APP_TOKEN

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Notion integration secret (same integration can serve multiple capabilities):
# - Page previews from notion.so links in threads (staffing_agent/notion_fetch.py)
# - Live People & Tags exclusions (staffing_agent/exclusions.py)
# Create integration: https://www.notion.so/my-integration — then share database “Staffing — People & Tags” with it.
NOTION_API_KEY=
# Legacy alias (read if NOTION_API_KEY is empty):
# NOTION_TOKEN=
# Optional override — People & Tags data source id (default baked in exclusions.py):
# STAFFING_NOTION_PEOPLE_DS_ID=73de0744-99bc-4ed9-a64a-ea35b5a15b94

# Optional: Google Docs API — plain text from docs.google.com links (Phase B + full reply previews)
# 1) GCP: enable "Google Docs API" for a project
# 2) IAM → Service account → Keys → JSON key file
# 3) Share each Doc with the service account email (Viewer), or use domain-wide delegation (advanced)
# Prefer a dedicated path so other tools can keep using GOOGLE_APPLICATION_CREDENTIALS for something else:
# STAFFING_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json
# Or reuse the standard env var:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# Anthropic — Claude Opus (default model id in code; override with ANTHROPIC_MODEL)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Internal LiteLLM / proxy: send requests here instead of api.anthropic.com (same as LITELLM_BASE_URL)
# Toloka: https://litellm.toloka.network (Cato may be required)
# LITELLM_BASE_URL=https://litellm.toloka.network
# ANTHROPIC_BASE_URL=https://litellm.toloka.network
# Model id must match what your proxy accepts (may differ from public Anthropic ids)
# ANTHROPIC_MODEL=claude-opus-4-6

# Set to 1 to force mock LLM (no Anthropic call) for local testing
# STAFFING_AGENT_MOCK_LLM=0

# Optional: force Phase B tier (1–4) for every staffing @mention / paste — overrides LLM classification.
# Use e.g. 3 to always get Tier 3 team layout (SO + SoE + WFM) and project_staffing inline lines.
# STAFFING_FORCE_TIER=3

# Optional: Databricks CLI profile for `python -m staffing_agent --check-dbx` and Node 3 capacity SQL
# (brew install databricks; databricks auth login --profile toloka)
# DATABRICKS_PROFILE=toloka

# Cursor MCP: Databricks (managed MCP endpoint + uc-mcp-proxy). Requires `uv` / `uvx` (https://docs.astral.sh/uv/getting-started/installation/).
# After `databricks auth login --profile <profile>`, set:
# DATABRICKS_MCP_URL=https://<workspace-host>/api/2.0/mcp/functions/system/ai
# Example host: your workspace URL without path, e.g. https://dbc-xxxxxxxx.cloud.databricks.com
# DATABRICKS_PROFILE must match the CLI profile used for `databricks auth login`.
# Optional: pass SQL warehouse id into MCP tool calls, e.g. add to .cursor/mcp.json args: "--meta", "warehouse_id=<warehouse-id>"
# Override paths to SQL from Notion (defaults under sql/)
# STAFFING_CAPACITY_SQL_PATH=
# (Legacy alias still read if set: STAFFING_OCCUPATION_SQL_PATH)
# Per-person project rows (join staffing + orders) — shown for recommended people in minimal/compact
# STAFFING_PROJECT_STAFFING_SQL_PATH=
# HiBob work start dates (onboarding footer in Slack). Default sql/hibob_start_dates.sql
# STAFFING_HIBOB_START_DATES_SQL_PATH=
# Run SELECT 1 from Slack replies (adds latency); default off
# STAFFING_AGENT_SLACK_DBX_SMOKE=0

# Reply shape: minimal = краткое саммари + только рекомендация (default); compact = + Node 2 + превью Capacity; full = Phase A + JSON + всё
# STAFFING_AGENT_REPLY_STYLE=minimal

# Max characters of Slack thread text sent to Phase B (default 50000). Lower e.g. 3500 if you need smaller Anthropic prompts.
# STAFFING_THREAD_PREVIEW_MAX_CHARS=50000

# Team capacity — split BY ROLE detail into sequential Slack messages under this size (default 11000; clamped 400–39000).
# STAFFING_TEAM_CAPACITY_CHUNK_CHARS=11000

# People & Tags CSV (Notion export) для склейки по email; по умолчанию config/notion_export/staffing_people_tags_all.csv
# STAFFING_PEOPLE_CSV_PATH=

# Projects & Offers Classification CSV — блок «похожие проекты»; по умолчанию config/notion_export/projects_offers_classification_0.csv
# STAFFING_PROJECTS_CLASSIFICATION_CSV_PATH=

# Optional: paste pipeline — post CLI result to a channel (channel ID starts with C)
# python -m staffing_agent --process-paste thread.txt --post-slack-channel C01234567890
